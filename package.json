{
  "name": "factorio-web-ts",
  "version": "0.1.0",
  "description": "FactorioWeb TypeScript migration - New architecture",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "init": "tsx src/scripts/init.ts",
    "init:check": "tsx src/scripts/init.ts --check",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/jwt": "^9.0.1",
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.0.1",
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^11.7.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.1.0",
    "jsonwebtoken": "^9.0.3",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^5.0.2",
    "@types/better-sqlite3": "^7.6.12",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.1",
    "eslint": "^10.3.0",
    "jiti": "^2.7.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3"
  }
}
